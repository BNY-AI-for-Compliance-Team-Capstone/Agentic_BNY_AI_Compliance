{
  "report_type": "CTR",
  "version": "1.0",
  "effective_date": "2026-02-27",
  "form_number": "FinCEN Form 112",
  "template_file": "knowledge_base/documents/pdf_templates/ctr_report.pdf",
  "description": "Normalized case-input schema used by CTR filing logic.",
  "input_payload_schema": {
    "oneOf": [
      {
        "type": "object",
        "$ref": "#/definitions/case"
      },
      {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/definitions/case"
        }
      }
    ]
  },
  "definitions": {
    "case": {
      "type": "object",
      "properties": {
        "case_id": {
          "type": "string"
        },
        "report_type": {
          "type": "string"
        },
        "subject": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "country": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ]
        },
        "institution": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "ein": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "branch_city": {
              "type": "string"
            },
            "branch_state": {
              "type": "string"
            },
            "contact_officer": {
              "type": "string"
            },
            "contact_phone": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ]
        },
        "SuspiciousActivityInformation": {
          "type": "object",
          "properties": {
            "26_AmountInvolved": {
              "type": "object",
              "properties": {
                "amount_usd": {
                  "type": [
                    "number",
                    "string"
                  ]
                }
              }
            }
          }
        },
        "transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tx_id": {
                "type": "string"
              },
              "timestamp": {
                "type": "string"
              },
              "amount_usd": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "origin_account": {
                "type": "string"
              },
              "destination_account": {
                "type": "string"
              },
              "product_type": {
                "type": "string"
              },
              "instrument_type": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "subject",
        "institution"
      ]
    }
  }
}
